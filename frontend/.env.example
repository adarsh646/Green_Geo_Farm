# Backend API base URL used by axios and API URL helpers.
# Leave empty in production if your web server reverse-proxies /api to backend.
# Example explicit value: http://your-server:5000
VITE_API_BASE_URL=

# Dev-only API target for Vite proxy (/api, /uploads).
VITE_DEV_API_TARGET=http://localhost:5000

# Request timeout in milliseconds.
VITE_API_TIMEOUT_MS=20000

# Camera microservice endpoints.
VITE_CAMERA_BASE_URL=http://127.0.0.1:8000
# VITE_CAMERA_WS_URL=ws://127.0.0.1:8000/ws

# Optional cow-health service overrides.
VITE_COW_HEALTH_API_BASE_URL=
# VITE_COW_HEALTH_WS_URL=ws://localhost:5000/ws
